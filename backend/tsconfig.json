{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "outDir": "dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "baseUrl": "./src",
        "paths": {
            "@services/*": ["services/*"]
        },
        "ignoreDeprecations": "6.0"
    },
    "include": ["src/**/*"]
}